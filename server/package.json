{
  "name": "spare-parts-server",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "src/index.js",
  "bin": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "node prisma/seed.js",
    "build": "pkg . --targets node18-win-x64 --output spare-parts-server.exe",
    "build:win32": "pkg . --targets node18-win --output spare-parts-server.exe"
  },
  "pkg": {
    "scripts": [
      "src/**/*.js",
      "prisma/**/*.js"
    ],
    "assets": [
      "prisma/**/*",
      "public/**/*",
      "node_modules",
      "node_modules/es-get-iterator/**/*",
      ".env*"
    ],
    "targets": [
      "node18-win-x64"
    ]
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.15.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "pkg": "^5.8.1",
    "prisma": "^5.20.0"
  },
  "allowScripts": {
    "@prisma/client@5.22.0": true,
    "@prisma/engines@5.22.0": true,
    "prisma@5.22.0": true
  }
}
